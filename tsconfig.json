/* To learn more about this file see: https://angular.io/config/tsconfig. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "declaration": false,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "useDefineForClassFields": false,
    "baseUrl": ".",
    "paths": {
      "@jeppesen-foreflight/dp-dls-global-angular": ["../dp-dls-global-angular/dist/design/dp-dls-global-angular/index.d.ts"],
      "@jeppesen-foreflight/dp-dls-global-angular/*": ["../dp-dls-global-angular/dist/design/dp-dls-global-angular/*"],
      "@jeppesen-foreflight/dls-global-assets": ["../dp-dls-global-assets/dist"],
      "@jeppesen-foreflight/dls-global-assets/*": ["../dp-dls-global-assets/dist/*"]
    },
    "lib": [
      "ES2022",
      "dom"
    ]
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
}
