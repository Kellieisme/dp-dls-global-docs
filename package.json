{
  "name": "dls-global-docs",
  "version": "4.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:das": "ng serve --configuration=das --port 4201",
    "build": "ng build",
    "build:original": "ng build --configuration=production",
    "build:das": "ng build --configuration=das",
    "build:original:gh": "ng build --configuration=production --base-href /dp-dls-global-docs/original/",
    "build:das:gh": "ng build --configuration=das --base-href /dp-dls-global-docs/das/ --output-path=dist-das",
    "deploy:original": "npm run build:original:gh && gh-pages -d dist/dls-global-docs/browser -b gh-pages-original -e original",
    "deploy:das": "npm run build:das:gh && gh-pages -d dist-das/dls-global-docs/browser -b gh-pages-original -e das",
    "deploy:both": "npm run build:original:gh && npm run build:das:gh && gh-pages -d dist/dls-global-docs/browser -b gh-pages-original -e original && gh-pages -d dist-das/dls-global-docs/browser -b gh-pages-original -e das",
    "build:branch": "ng run dls-global-docs:build --base-href /design-system/dls-global-docs/${CI_COMMIT_REF_SLUG}/ --output-path=branch/${CI_COMMIT_REF_SLUG}",
    "build:prod": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.11",
    "@angular/cdk": "^20.2.12",
    "@angular/common": "^20.3.11",
    "@angular/compiler": "^20.3.11",
    "@angular/core": "^20.3.11",
    "@angular/forms": "^20.3.11",
    "@angular/material": "^20.2.12",
    "@angular/platform-browser": "^20.3.11",
    "@angular/platform-browser-dynamic": "^20.3.11",
    "@angular/router": "^20.3.11",
    "@jeppesen-foreflight/dp-dls-global-angular": "^3.5.1-pre.a8542aa",
    "bootstrap": "^5.3.8",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3.10",
    "@angular/cli": "^20.3.10",
    "@angular/compiler-cli": "^20.3.11",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^18.19.130",
    "gh-pages": "^6.3.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "^5.9.3"
  }
}
